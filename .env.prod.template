# Novel Content Audit System - Production Environment Configuration
# Copy this file to .env.prod and fill in your actual values

# =============================================================================
# CORE SYSTEM CONFIGURATION
# =============================================================================

# Environment
ENVIRONMENT=production

# Security Keys (REQUIRED - Generate secure random keys)
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-minimum-32-characters

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=120

# =============================================================================
# EXTERNAL SERVICE CONFIGURATION
# =============================================================================

# OpenAI Configuration (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3

# Database Configuration
DATABASE_URL=sqlite:///data/novel_audit.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Vector Store Configuration
VECTOR_STORE_PATH=/data/chroma_db
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Cache Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Configuration
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com,localhost

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# API Key Authentication
API_KEY_HEADER=X-API-Key
API_KEYS=api-key-1,api-key-2,api-key-3

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/app/logs/novel-audit.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# Metrics and Monitoring
METRICS_ENABLED=true
METRICS_PORT=8001
PROMETHEUS_METRICS=true

# Sentry (Error Tracking) - Optional
SENTRY_DSN=https://your-sentry-dsn-here
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Workflow Configuration
MAX_CONCURRENT_AUDITS=10
AUDIT_TIMEOUT_SECONDS=120
RAG_SIMILARITY_THRESHOLD=0.7
CONFIDENCE_HIGH_THRESHOLD=0.8
CONFIDENCE_LOW_THRESHOLD=0.3

# Caching
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Background Tasks
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKERS=2

# =============================================================================
# BACKUP AND RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true

# S3 Backup (Optional)
S3_BACKUP_BUCKET=your-backup-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# =============================================================================
# SERVICE-SPECIFIC CONFIGURATION
# =============================================================================

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-this-secure-password

# Elasticsearch
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=change-this-elastic-password

# Nginx
NGINX_CLIENT_MAX_BODY_SIZE=10M
NGINX_WORKER_CONNECTIONS=1024

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Human Review System
HUMAN_REVIEW_ENABLED=true
HUMAN_REVIEW_QUEUE_SIZE=1000
HUMAN_REVIEW_PRIORITY_WEIGHTS=high:10,medium:5,low:1

# Training Data Management
TRAINING_DATA_AUTO_UPDATE=true
TRAINING_DATA_UPDATE_INTERVAL=weekly

# Advanced Features
MULTI_MODAL_ANALYSIS_ENABLED=true
RAG_ENHANCEMENT_ENABLED=true
ARBITRATION_SYSTEM_ENABLED=true

# =============================================================================
# DEVELOPMENT/DEBUG (Only for non-production environments)
# =============================================================================

# Debug Settings (Should be false in production)
DEBUG=false
RELOAD=false

# Development Database (Don't use in production)
# DEV_DATABASE_URL=sqlite:///dev_novel_audit.db

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================

HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================

# Add any custom configuration variables here
# CUSTOM_FEATURE_ENABLED=true
# CUSTOM_API_ENDPOINT=https://your-custom-api.com
# CUSTOM_TIMEOUT=60